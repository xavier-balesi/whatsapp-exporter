<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Archive WhatsApp</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f0f2f5;
        }

        /* Conteneur principal style WhatsApp Web */
        .chat-container {
            max-width: 900px;
            margin: 0 auto;
            background-color: #efeae2;
            /* Wallpaper officiel WhatsApp */
            background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png');
            background-repeat: repeat;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            padding: 20px 5% 20px 5%;
            box-sizing: border-box;
        }

        /* Séparateur de date */
        .date-divider {
            align-self: center;
            background-color: #ffffff;
            color: #54656f;
            font-size: 12.5px;
            padding: 6px 12px;
            border-radius: 7.5px;
            margin: 16px 0;
            box-shadow: 0 1px 0.5px rgba(11,20,26,.13);
            text-transform: uppercase;
            font-weight: 500;
        }

        /* Structure globale d'une bulle */
        .message {
            max-width: 65%;
            margin-bottom: 4px; /* Rapproché si même émetteur */
            padding: 6px 8px 6px 9px;
            border-radius: 7.5px;
            font-size: 14.2px;
            line-height: 19px;
            color: #111b21;
            position: relative;
            box-shadow: 0 1px 0.5px rgba(11,20,26,.13);
            word-wrap: break-word;
            display: flex;
            flex-direction: column;
        }

        /* Alignement des bulles */
        .message.incoming {
            background-color: #ffffff;
            align-self: flex-start;
        }

        .message.outgoing {
            background-color: #d9fdd3;
            align-self: flex-end;
        }

        /* Nom de l'expéditeur (Utile pour les groupes) */
        .sender {
            font-size: 12.8px;
            font-weight: 600;
            color: #008069; /* Vert WhatsApp */
            margin-bottom: 4px;
        }

        /* Conteneur Média (Images & Vidéos) */
        .media-container {
            margin: -3px -5px 4px -5px; /* Élargit le média dans la bulle */
            border-radius: 6px;
            overflow: hidden;
            display: block;
        }

        .media-container img,
        .media-container video {
            max-width: 100%;
            max-height: 350px;
            object-fit: cover;
            display: block;
        }

        /* Modifié pour indiquer que les images sont cliquables */
        .media-container.whatsapp-image {
            cursor: pointer;
            transition: opacity 0.2s ease-in-out;
        }
        .media-container.whatsapp-image:hover {
            opacity: 0.9;
        }

        /* Contenu textuel */
        .text-content {
            white-space: pre-wrap; /* Préserve les retours à la ligne */
            margin-right: 40px; /* Laisse de la place pour l'heure à droite */
        }

        /* Heure du message */
        .timestamp {
            font-size: 11px;
            color: #667781;
            align-self: flex-end;
            position: absolute;
            bottom: 4px;
            right: 7px;
        }

        /* Ajustement de l'heure si le message n'est QU'UN média */
        .media-only .timestamp {
            background: rgba(11, 20, 26, 0.4);
            color: #ffffff;
            padding: 2px 6px;
            border-radius: 10px;
            bottom: 8px;
            right: 8px;
        }

        /* --- STYLE DE LA LIGHTBOX (Agrandissement) --- */
        #lightbox {
            display: none;
            position: fixed;
            z-index: 9999;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background-color: rgba(11, 20, 26, 0.9); /* Noir style WhatsApp Web */
            align-items: center;
            justify-content: center;
            cursor: zoom-out;
            opacity: 0;
            transition: opacity 0.25s ease-in-out;
        }

        #lightbox.active {
            display: flex;
            opacity: 1;
        }

        #lightbox-img {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain;
            box-shadow: 0 4px 24px rgba(0,0,0,0.5);
            border-radius: 4px;
            transform: scale(0.95);
            transition: transform 0.25s ease-in-out;
        }

        #lightbox.active #lightbox-img {
            transform: scale(1);
        }

        .close-lightbox {
            position: absolute;
            top: 20px; right: 25px;
            color: #aebac1;
            font-size: 35px;
            font-weight: 300;
            cursor: pointer;
            user-select: none;
            transition: color 0.2s;
        }
        .close-lightbox:hover {
            color: #ffffff;
        }
    </style>
</head>
<body>

    <div class="chat-container">

        {% set counter = namespace(last_date="") %}

        {% for message in messages %}
            {% if counter.last_date != message.date_txt %}
                {% set counter.last_date = message.date_txt %}
                <div class="date-divider">{{ message.date_txt }}</div>
            {% endif %}

            {% if user == message.name %}
                <div class="message outgoing">
            {% else %}
                <div class="message incoming">
                <div class="sender">{{ message.name }}</div>
            {% endif %}

            {% for image in message.images %}
                {# Ajout de la classe et du data-full pour le JS #}
                <div class="media-container whatsapp-image" data-full="{{ image }}">
                    <img src="{{ image }}" alt="Image WhatsApp">
                </div>
            {% endfor %}

            {% for video in message.videos %}
                <div class="media-container">
                    <video controls poster="{{ video }}">
                        <source src="{{ video }}" type="video/mp4">
                        Votre navigateur ne supporte pas la lecture de vidéos.
                    </video>
                </div>
            {% endfor %}

            {% for text in message.text %}
                <div class="text-content">{{ text }}</div>
            {% endfor %}

                <div class="timestamp">{{ message.time_txt }}</div>
                </div>
        {% endfor %}

    </div>

    <div id="lightbox">
        <span class="close-lightbox">&times;</span>
        <img id="lightbox-img" src="" alt="Image agrandie">
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const lightbox = document.getElementById('lightbox');
            const lightboxImg = document.getElementById('lightbox-img');
            const closeBtn = document.querySelector('.close-lightbox');
            const imageContainers = document.querySelectorAll('.whatsapp-image');

            // Ouvrir l'image au clic
            imageContainers.forEach(container => {
                container.addEventListener('click', function() {
                    const fullImageUrl = this.getAttribute('data-full');
                    lightboxImg.src = fullImageUrl;
                    lightbox.classList.add('active');
                    document.body.style.overflow = 'hidden'; // Bloque le scroll arrière
                });
            });

            // Fermer proprement
            function closeLightbox() {
                lightbox.classList.remove('active');
                document.body.style.overflow = ''; // Relâche le scroll
                setTimeout(() => { lightboxImg.src = ''; }, 250); // Clean la src après l'animation
            }

            // Bind des events de fermeture (Click et Escape)
            closeBtn.addEventListener('click', closeLightbox);

            lightbox.addEventListener('click', function(e) {
                if (e.target === lightbox || e.target === closeBtn) {
                    closeLightbox();
                }
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && lightbox.classList.contains('active')) {
                    closeLightbox();
                }
            });
        });
    </script>

</body>
</html>
